{
  "name": "nostr-swarm",
  "version": "0.1.0",
  "description": "A fully peer-to-peer Nostr relay that syncs events over Hyperswarm",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nostr-swarm": "./dist/cli.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sovITxyz/nostr-swarm.git"
  },
  "author": "sovITxyz",
  "homepage": "https://github.com/sovITxyz/nostr-swarm#readme",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "nostr",
    "relay",
    "p2p",
    "hyperswarm",
    "holepunch",
    "decentralized"
  ],
  "license": "MIT",
  "dependencies": {
    "autobase": "^7.27.3",
    "b4a": "^1.6.7",
    "compact-encoding": "^2.15.0",
    "corestore": "^7.9.2",
    "graceful-goodbye": "^1.3.0",
    "hyperbee": "^2.27.3",
    "hyperswarm": "^4.17.0",
    "nostr-tools": "^2.23.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
